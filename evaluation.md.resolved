## 7. Схема базы данных (ER-диаграмма)

```mermaid
erDiagram
    customers ||--o{ applications : "подаёт"
    consultants ||--o{ applications : "обрабатывает"
    services ||--o{ applications : "указана в"
    applications ||--o{ application_documents : "содержит"
    applications ||--o{ proposals : "анализируется"
    consultants ||--o{ proposals : "создаёт"

    customers {
        int id PK
        varchar full_name
        varchar email UK
        varchar phone
        varchar password_hash
        varchar iin_bin UK
        varchar city_region
        varchar business_name
        varchar business_type
    }

    consultants {
        int id PK
        varchar full_name
        varchar email UK
        varchar employee_id UK
        varchar department
        varchar password_hash
    }

    services {
        int id PK
        varchar name
        text description
        decimal interest_rate
        decimal max_amount
        varchar loan_type
        boolean active
    }

    applications {
        int id PK
        int customer_id FK
        int service_id FK
        int consultant_id FK
        decimal amount
        text purpose
        enum status
    }

    application_documents {
        int id PK
        int application_id FK
        varchar file_path
        varchar file_name
        varchar document_type
    }

    proposals {
        int id PK
        int application_id FK
        int consultant_id FK
        decimal scoring_points
        varchar risk_level
        decimal recommended_amount
        text ai_summary
        enum status
    }

    activity_log {
        int id PK
        int user_id
        enum user_type
        varchar action
        text details
    }
```
